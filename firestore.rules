rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
        request.auth.token.email == 'gabrielpe3109@gmail.com';
    }

    function isVerifiedAdmin() {
      return isAdmin();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Entity Validations ---

    function isValidUserSettings(data) {
      return data.notificationsEnabled is bool &&
        data.advanceDays is number &&
        data.currency is string &&
        data.currency.size() <= 10 &&
        data.email is string &&
        data.plan in ['basic', 'premium'] &&
        data.role in ['admin', 'user'] &&
        data.premiumStatus in ['none', 'pending', 'approved', 'rejected'] &&
        data.productLimit is number &&
        data.productCount is number;
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() <= 100 &&
        data.category is string &&
        data.userId == request.auth.uid &&
        data.expiryDate is string;
    }

    function isValidPayment(data) {
      return data.userId == request.auth.uid &&
        data.userEmail == request.auth.token.email &&
        data.status in ['pendente', 'aprovado', 'rejeitado'] &&
        data.referencia is string;
    }

    // --- Matches ---

    // 1. User Email Index (used for uniqueness check)
    match /users/{email} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if false; // Immutable index
    }

    // 2. User Settings
    match /userSettings/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow delete: if isVerifiedAdmin();
      
      allow create: if isOwner(userId) && 
        (incoming().role == 'user' || (incoming().role == 'admin' && request.auth.token.email == 'gabrielpe3109@gmail.com')) && 
        incoming().plan == 'basic' && 
        incoming().productLimit == 100 &&
        incoming().premiumStatus == 'none' &&
        isValidUserSettings(incoming());
        
      allow update: if (isOwner(userId) || isVerifiedAdmin()) && (
        // Admin can change anything (for manual role/plan setting)
        isVerifiedAdmin() || 
        // Allow master admin email to promote itself during initialization if needed
        (isOwner(userId) && request.auth.token.email == 'gabrielpe3109@gmail.com') ||
        // User can only change specific fields
        (
          isOwner(userId) && 
          incoming().diff(existing()).affectedKeys().hasOnly(['notificationsEnabled', 'advanceDays', 'currency', 'photoURL', 'displayName', 'premiumStatus', 'productCount', 'updatedAt']) &&
          // User CANNOT change their own role or plan or productLimit
          incoming().role == existing().role &&
          incoming().plan == existing().plan &&
          incoming().productLimit == existing().productLimit &&
          // User can only set premiumStatus to pending (if requesting)
          (incoming().premiumStatus == existing().premiumStatus || incoming().premiumStatus == 'pending')
        )
      );
    }

    // 3. Products
    match /products/{productId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidProduct(incoming()) && 
        (isVerifiedAdmin() || get(/databases/$(database)/documents/userSettings/$(request.auth.uid)).data.productCount < get(/databases/$(database)/documents/userSettings/$(request.auth.uid)).data.productLimit);
      allow update: if (resource.data.userId == request.auth.uid || isVerifiedAdmin()) && isValidProduct(incoming());
      allow delete: if resource.data.userId == request.auth.uid || isVerifiedAdmin();
    }

    // 4. Categories
    match /categories/{categoryId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if (resource.data.userId == request.auth.uid || isVerifiedAdmin());
      allow delete: if (resource.data.userId == request.auth.uid || isVerifiedAdmin());
    }

    // 5. Payments
    match /payments/{paymentId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().status == 'pendente' && isValidPayment(incoming());
      allow update: if isVerifiedAdmin() && incoming().status in ['aprovado', 'rejeitado'];
      allow delete: if isVerifiedAdmin();
    }

    // 6. Notifications
    match /notifications/{notificationId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }
  }
}
