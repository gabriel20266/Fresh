rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Product validation
    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.expiryDate is string 
        && data.category is string && data.category.size() <= 50
        && data.userId == request.auth.uid
        && (!('price' in data) || data.price == null || data.price is number)
        && (!('observations' in data) || data.observations == null || (data.observations is string && data.observations.size() <= 1000))
        && (!('imageURL' in data) || data.imageURL == null || (data.imageURL is string && data.imageURL.size() < 1048576));
    }

    // Category validation
    function isValidCategory(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 50
        && data.userId == request.auth.uid;
    }

    // UserSettings validation
    function isValidUserSettings(data) {
      return data.notificationsEnabled is bool
        && (data.advanceDays is int || data.advanceDays is float)
        && data.currency is string && data.currency.size() <= 10
        && data.plan in ['free', 'premium']
        && (!('productCount' in data) || (data.productCount is int || data.productCount is float))
        && (!('email' in data) || (data.email is string && data.email.size() <= 200))
        && (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() < 1048576))
        && (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100))
        && (!('updatedAt' in data) || (data.updatedAt is string && data.updatedAt.size() <= 50));
    }

    match /users/{email} {
      allow get: if true; 
      allow create: if isSignedIn() && request.auth.token.email.lower() == email.lower();
    }

    match /products/{productId} {
      allow get: if isSignedIn() && isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(productId)
        && isValidProduct(incoming())
        && incoming().createdAt == request.time
        && incoming().keys().hasAll(['name', 'expiryDate', 'category', 'userId', 'createdAt', 'updatedAt']);
        
      allow update: if isSignedIn()
        && isOwner(existing().userId)
        && isValidProduct(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'expiryDate', 'category', 'price', 'observations', 'imageURL', 'updatedAt']);
        
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    match /userSettings/{userId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow write: if isSignedIn() && isOwner(userId) && isValidUserSettings(incoming());
    }

    match /categories/{categoryId} {
      allow get: if isSignedIn() && isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(categoryId) && isValidCategory(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && isOwner(existing().userId) && isValidCategory(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['name']);
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }
  }
}
